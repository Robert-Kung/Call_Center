# ===================================
# 前端環境變數 (Vite)
# ===================================

# Gemini Live API Key（已改用 token-server 簽發 ephemeral token，前端不應持有此 key）
# 開發 fallback 用：若 token-server 未啟動，可暫時填入 API key
VITE_GEMINI_API_KEY=

# Token Server URL（選填，預設透過 Vite proxy 轉發到 localhost:3001）
# VITE_TOKEN_SERVER_URL=/api/gemini-token

# Gemini 模型名稱（選填，預設 gemini-2.5-flash-native-audio-preview-12-2025）
VITE_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# REST WebSocket 後端 URL（WS Live 模式必填）
# Dev: 可用 Vite proxy 路徑 (ws://localhost:3100/ws) 或直接指向後端
VITE_REST_WS_URL=ws://192.168.2.100:3000/ws

# 後端 API 伺服器位址（選填，用於 Vite dev proxy）
VITE_BACKEND_HOST=192.168.2.100
VITE_BACKEND_PORT=3000

# ===================================
# 後端環境變數 (my-voice-agent/)
# 請複製到 my-voice-agent/.env
# ===================================

# 後端服務埠號
# PORT=3000

# ASR 語音辨識 API
# ASR_API_URL=http://localhost:8001/asr

# LLM 大語言模型 API
# LLM_API_URL=http://localhost:8002/chat

# TTS 語音合成 API
# TTS_API_URL=http://localhost:8003/tts
